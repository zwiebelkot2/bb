# Optional: OpenAI curation for arXiv papers
OPENAI_API_KEY=
NUXT_OPENAI_API_KEY=
NUXT_SCIENCE_CURATOR_PROMPT=Pick the most interesting and accessible papers for an educated audience. Avoid pure optimizations; prefer new methods, biology, AI with clear findings.

# Gemini: daily web search (Google Search Grounding)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
NUXT_GEMINI_API_KEY=
NUXT_GEMINI_MODEL=gemini-2.5-flash
# Leave empty to use prompts/gemini-web.txt
NUXT_GEMINI_WEB_PROMPT=

# Refresh secret (for POST /api/refresh)
NUXT_REFRESH_SECRET=

# Vercel Cron secret (auto-set by Vercel, or set manually)
CRON_SECRET=
